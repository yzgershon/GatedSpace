{
	"name": "@superset/auth",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"exports": {
		"./server": {
			"types": "./src/server.ts",
			"default": "./src/server.ts"
		},
		"./client": {
			"types": "./src/client.ts",
			"default": "./src/client.ts"
		},
		"./env": {
			"types": "./src/env.ts",
			"default": "./src/env.ts"
		},
		"./stripe": {
			"types": "./src/stripe.ts",
			"default": "./src/stripe.ts"
		}
	},
	"scripts": {
		"clean": "git clean -xdf .cache .turbo dist node_modules",
		"test": "bun test",
		"typecheck": "tsc --noEmit --emitDeclarationOnly false"
	},
	"dependencies": {
		"@better-auth/api-key": "1.6.13",
		"@better-auth/expo": "1.6.13",
		"@better-auth/oauth-provider": "1.6.13",
		"@better-auth/stripe": "1.6.13",
		"@superset/db": "workspace:*",
		"@superset/email": "workspace:*",
		"@superset/shared": "workspace:*",
		"@t3-oss/env-core": "0.13.11",
		"@t3-oss/env-nextjs": "0.13.11",
		"@upstash/qstash": "2.10.1",
		"@upstash/ratelimit": "2.0.8",
		"@upstash/redis": "1.37.0",
		"better-auth": "1.6.13",
		"dotenv": "17.3.1",
		"drizzle-orm": "0.45.2",
		"resend": "4.8.0",
		"stripe": "20.4.1",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@superset/typescript": "workspace:*",
		"@types/node": "24.12.0",
		"typescript": "6.0.3"
	}
}
