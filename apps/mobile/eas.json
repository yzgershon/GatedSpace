{
	"cli": {
		"version": ">= 16.0.0",
		"appVersionSource": "remote"
	},
	"build": {
		"development": {
			"developmentClient": true,
			"distribution": "internal"
		},
		"preview": {
			"distribution": "internal",
			"environment": "preview"
		},
		"e2e-test": {
			"withoutCredentials": true,
			"ios": {
				"simulator": true
			},
			"env": {
				"EXPO_PUBLIC_E2E": "1"
			}
		},
		"production": {
			"autoIncrement": true,
			"environment": "production"
		}
	},
	"submit": {
		"production": {
			"ios": {
				"ascAppId": "6788926383",
				"appleTeamId": "NV9657CS5A",
				"metadataPath": "./store.config.json"
			}
		}
	}
}
